#!/usr/bin/env bash
# bin/test-frontmatter — validate every .claude/skills/*/SKILL.md frontmatter
#
# Contract enforced (see .claude/skills/CONVENTIONS.md):
#   1. YAML frontmatter present (delimited by `---` lines).
#   2. `name:` non-empty and equals the parent folder name.
#   3. `description:` non-empty and starts with `Use when`.
#   4. `user-invocable:` is exactly `true` or `false`.
#   5. `tier:` is one of `rigid | flexible | util`.
#   6. `kind:` is one of `process | implementation | verification`,
#      or absent only when `tier: util`.
#
# Exits 0 on full pass, 1 on any non-conformance. Always prints a per-skill
# PASS/FAIL line and a final summary.

set -u

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$repo_root" ]; then
  echo "FAIL: not inside a git repo" >&2
  exit 1
fi
cd "$repo_root" || exit 1

skills_dir=".claude/skills"
if [ ! -d "$skills_dir" ]; then
  echo "FAIL: $skills_dir not found" >&2
  exit 1
fi

fail=0
total=0
pass=0

# Read the full frontmatter in one awk pass. Emits exactly 6 lines:
#   line 1: yes | no  (was there frontmatter at all?)
#   line 2: name
#   line 3: description
#   line 4: user-invocable
#   line 5: tier
#   line 6: kind
# Missing keys produce an empty line. Replaces six previous awk forks per skill
# (5 extract_field + 1 has_frontmatter) with one — the validator handles ~70
# skills, so this is ~420 fewer subprocess starts per run.
read_frontmatter() {
  local file="$1"
  awk '
    function clean(v) {
      sub(/^[[:space:]]+/, "", v)
      sub(/[[:space:]]+$/, "", v)
      if (v ~ /^".*"$/) v = substr(v, 2, length(v)-2)
      else if (v ~ /^'\''.*'\''$/) v = substr(v, 2, length(v)-2)
      return v
    }
    function getval(line, key,    pat, v) {
      pat = "^[[:space:]]*" key "[[:space:]]*:"
      if (match(line, pat)) {
        v = substr(line, RSTART+RLENGTH)
        return clean(v)
      }
      return ""
    }
    BEGIN { has_fm="no"; in_fm=0 }
    NR==1 {
      if ($0 ~ /^---[[:space:]]*$/) { has_fm="yes"; in_fm=1; next }
      exit
    }
    in_fm && /^---[[:space:]]*$/ { in_fm=0; exit }
    in_fm {
      if (nm == "") { v=getval($0, "name");           if (v != "") nm=v }
      if (ds == "") { v=getval($0, "description");    if (v != "") ds=v }
      if (ui == "") { v=getval($0, "user-invocable"); if (v != "") ui=v }
      if (tr == "") { v=getval($0, "tier");           if (v != "") tr=v }
      if (kd == "") { v=getval($0, "kind");           if (v != "") kd=v }
    }
    END { print has_fm; print nm; print ds; print ui; print tr; print kd }
  ' "$file"
}

for skill_md in "$skills_dir"/*/SKILL.md; do
  total=$((total + 1))
  folder="$(basename "$(dirname "$skill_md")")"
  errs=()

  {
    IFS= read -r has_fm
    IFS= read -r name
    IFS= read -r description
    IFS= read -r user_invocable
    IFS= read -r tier
    IFS= read -r kind
  } < <(read_frontmatter "$skill_md")

  if [ "$has_fm" != "yes" ]; then
    errs+=("missing YAML frontmatter (must start with --- on line 1)")
    fail=$((fail + 1))
    echo "FAIL  $folder"
    for e in "${errs[@]}"; do echo "       - $e"; done
    continue
  fi

  if [ -z "$name" ]; then
    errs+=("name: missing or empty")
  elif [ "$name" != "$folder" ]; then
    errs+=("name: '$name' does not match folder '$folder'")
  fi

  if [ -z "$description" ]; then
    errs+=("description: missing or empty")
  else
    case "$description" in
      "Use when"*) ;;
      *) errs+=("description: must start with 'Use when' (got: '$(printf %.60s "$description")…')") ;;
    esac
  fi

  case "$user_invocable" in
    true|false) ;;
    "") errs+=("user-invocable: missing") ;;
    *) errs+=("user-invocable: must be 'true' or 'false' (got: '$user_invocable')") ;;
  esac

  case "$tier" in
    rigid|flexible|util) ;;
    "") errs+=("tier: missing") ;;
    *) errs+=("tier: must be rigid|flexible|util (got: '$tier')") ;;
  esac

  if [ -z "$kind" ]; then
    if [ "$tier" != "util" ]; then
      errs+=("kind: required when tier is '$tier' (only 'util' may omit kind)")
    fi
  else
    case "$kind" in
      process|implementation|verification) ;;
      *) errs+=("kind: must be process|implementation|verification (got: '$kind')") ;;
    esac
    if [ "$tier" = "util" ]; then
      errs+=("kind: must be absent when tier is 'util' (got: '$kind')")
    fi
  fi

  if [ ${#errs[@]} -eq 0 ]; then
    pass=$((pass + 1))
    echo "PASS  $folder"
  else
    fail=$((fail + 1))
    echo "FAIL  $folder"
    for e in "${errs[@]}"; do echo "       - $e"; done
  fi
done

echo
echo "Frontmatter validation: $pass/$total passed, $fail failed."
[ "$fail" -eq 0 ] || exit 1
