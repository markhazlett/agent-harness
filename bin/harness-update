#!/usr/bin/env bash
# =============================================================================
# harness-update — Pull the latest agent-harness into the current project.
#
# Two-phase usage (the /harness-update skill drives it):
#
#   1. bin/harness-update --plan
#        Sync upstream into ~/.agent-harness/source, classify each upstream-
#        managed file as install / update-safe / conflict / skip, and emit
#        the plan as JSON on stdout. No writes to the project tree.
#
#   2. bin/harness-update --apply --resolve <resolution-json> [--from <plan-json>]
#        Apply the plan. Conflicts are decided by the resolution file.
#        Writes ~/.agent-harness/installed-manifest.json (provenance) and
#        ~/.agent-harness/just-upgraded-from (consumed by harness-update-check).
#
# Files this script manages (managed = read from upstream and copied to local):
#   skills/<skill>/...    (canonical; .claude/skills is a symlink → here)
#   agents/*.md           (canonical; .claude/agents is a symlink → here)
#   prompts/*.md          (canonical; .claude/commands is a symlink → here)
#   .claude/hooks/*.sh    (except config.sh — always preserved)
#   bin/*                 (harness binaries; excludes this very script's caller)
#   VERSION
#   setup.sh
#
# Files this script NEVER touches:
#   .claude/hooks/config.sh           (project config written by setup.sh)
#   .claude/settings.json             (project hook wiring)
#   anything outside the managed prefixes above
#   any local-only file inside the managed prefixes (e.g. a custom skill dir
#     that has no upstream counterpart) — surfaced in the plan as `local_only`.
# =============================================================================

set -uo pipefail

# ── Config ──────────────────────────────────────────────────────────────────

UPSTREAM_REPO="https://github.com/markhazlett/agent-harness.git"
UPSTREAM_BRANCH="main"
STATE_DIR="${HARNESS_STATE_DIR:-${HOME}/.agent-harness}"
SOURCE_DIR="${HARNESS_SOURCE_DIR:-${STATE_DIR}/source}"
MANIFEST_FILE="${STATE_DIR}/installed-manifest.json"
JUST_UPGRADED_FILE="${STATE_DIR}/just-upgraded-from"
CACHE_FILE="${STATE_DIR}/last-update-check"

# When HARNESS_SOURCE_DIR is set (tests), trust the caller-provided source tree
# and skip the network fetch — the dir must already be a valid harness checkout.
HARNESS_SKIP_SYNC="${HARNESS_SOURCE_DIR:+1}"

# ── Helpers ─────────────────────────────────────────────────────────────────

die() { echo "harness-update: $*" >&2; exit 1; }

require() {
  command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"
}

sha256() {
  # macOS ships shasum; Linux usually has sha256sum. Fall back gracefully.
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  else
    shasum -a 256 "$1" | awk '{print $1}'
  fi
}

is_managed() {
  # Return 0 if the upstream-relative path is one we install into a project.
  # Upstream's .claude/skills, .claude/agents, .claude/commands are git symlinks
  # to the canonical top-level skills/, agents/, prompts/ trees, so we manage
  # those top-level paths directly — git ls-files won't descend into the
  # symlinks themselves.
  case "$1" in
    skills/*|\
    agents/*|\
    prompts/*|\
    .claude/hooks/*|\
    bin/*|\
    VERSION|\
    setup.sh) return 0 ;;
    *) return 1 ;;
  esac
}

is_preserved() {
  # Return 0 if the path must NEVER be overwritten, even if upstream ships it.
  # config.sh holds the user's setup.sh answers (test command, app name, etc.);
  # the upstream-shipped copy is a placeholder we must not propagate.
  case "$1" in
    .claude/hooks/config.sh) return 0 ;;
    *) return 1 ;;
  esac
}

# ── Layout migration ────────────────────────────────────────────────────────
# Pre-flip installs have .claude/{skills,agents,commands} as real directories.
# Post-flip upstream ships top-level skills/, agents/, prompts/ with .claude/*
# as symlinks. Without an in-place migration, /harness-update would strand
# every upstream skill at top-level where Claude Code can't see it.

# Mapping: <.claude name>:<canonical top-level name>. Note commands → prompts.
LAYOUT_MIGRATION_PAIRS=("skills:skills" "agents:agents" "commands:prompts")

detect_old_layout() {
  # Emit "<from>\t<to>" lines for each .claude/<X> that needs migration.
  # A migration is needed when .claude/<X> is a real directory (not a symlink)
  # AND the canonical top-level dir does not exist yet. If both exist we die
  # loudly — that's a partial layout the user must reconcile manually.
  for pair in "${LAYOUT_MIGRATION_PAIRS[@]}"; do
    local cn="${pair%%:*}"
    local tn="${pair##*:}"
    local cp="${REPO_ROOT}/.claude/${cn}"
    local tp="${REPO_ROOT}/${tn}"

    # Already a symlink or missing — nothing to migrate for this entry.
    [ -d "$cp" ] && [ ! -L "$cp" ] || continue

    if [ -e "$tp" ]; then
      die "layout migration blocked: both .claude/${cn}/ and ${tn}/ exist — please reconcile manually before re-running"
    fi

    printf '%s\t%s\n' ".claude/${cn}" "${tn}"
  done
}

layout_migration_json() {
  # Build a JSON array of {from, to} from detect_old_layout output.
  local lines; lines="$(detect_old_layout)"
  if [ -z "$lines" ]; then
    echo "[]"
    return 0
  fi
  jq -Rn '[inputs | split("\t") | {from: .[0], to: .[1]}]' <<<"$lines"
}

rewrite_manifest_for_migration() {
  # Rewrite manifest keys whose prefix matches a just-migrated <from>/
  # to the new <to>/. Only applied for prefixes we actually migrated, so
  # unrelated entries (and entries for layouts we left alone) stay put.
  # $@ = "<from>\t<to>" tab-separated pairs.
  [ -f "$MANIFEST_FILE" ] || return 0
  [ "$#" -gt 0 ] || return 0

  # Build a jq object: { "<from>/": "<to>/", ... } and use it to rewrite keys.
  local map_lines; map_lines=$(mktemp) || die "rewrite_manifest: mktemp failed"
  for pair in "$@"; do
    local from="${pair%%$'\t'*}"
    local to="${pair##*$'\t'}"
    jq -nc --arg f "${from}/" --arg t "${to}/" '{($f): $t}' >> "$map_lines"
  done
  local map; map="$(jq -cs 'add // {}' "$map_lines")"
  rm -f "$map_lines"

  local tmp="${MANIFEST_FILE}.tmp.$$"
  jq --argjson map "$map" '
    .files |= with_entries(
      .key |= (. as $k
        | ($map | to_entries | map(select(.key as $p | $k | startswith($p))) | first) as $hit
        | if $hit == null then $k else ($hit.value + ($k | ltrimstr($hit.key))) end
      )
    )
  ' "$MANIFEST_FILE" > "$tmp" \
    || { rm -f "$tmp"; die "manifest rewrite jq failed"; }
  mv "$tmp" "$MANIFEST_FILE" \
    || { rm -f "$tmp"; die "manifest rewrite rename failed"; }
}

migrate_layout() {
  local pairs; pairs="$(detect_old_layout)"
  if [ -z "$pairs" ]; then
    die "no layout migration needed (no real-directory .claude/{skills,agents,commands} found)"
  fi

  local applied=()
  while IFS=$'\t' read -r from to; do
    [ -z "$from" ] && continue
    local from_path="${REPO_ROOT}/${from}"
    local to_path="${REPO_ROOT}/${to}"

    mv "$from_path" "$to_path" \
      || die "migrate: mv ${from_path} → ${to_path} failed"
    ln -s "../${to}" "$from_path" \
      || die "migrate: symlink ${from_path} → ../${to} failed"

    applied+=("${from}"$'\t'"${to}")
    echo "  migrated: ${from} → ${to}/ (with symlink)" >&2
  done <<<"$pairs"

  if [ "${#applied[@]}" -gt 0 ]; then
    rewrite_manifest_for_migration "${applied[@]}"
    [ -f "$MANIFEST_FILE" ] && echo "  manifest paths rewritten" >&2
  fi
}

# ── Setup ───────────────────────────────────────────────────────────────────

require git
require jq

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" \
  || die "not inside a git repository — run this from your project root"

LOCAL_VERSION_FILE="${REPO_ROOT}/VERSION"
[ -f "$LOCAL_VERSION_FILE" ] \
  || die "no VERSION file at ${LOCAL_VERSION_FILE} — this doesn't look like a harness install"

LOCAL_VERSION="$(tr -d '[:space:]' < "$LOCAL_VERSION_FILE")"

mkdir -p "$STATE_DIR"

# ── Upstream sync ───────────────────────────────────────────────────────────

sync_upstream() {
  if [ -n "$HARNESS_SKIP_SYNC" ]; then
    [ -d "$SOURCE_DIR" ] || die "HARNESS_SOURCE_DIR=${SOURCE_DIR} does not exist"
    return 0
  fi
  if [ -d "${SOURCE_DIR}/.git" ]; then
    git -C "$SOURCE_DIR" fetch --quiet origin "$UPSTREAM_BRANCH" \
      || die "failed to fetch upstream from ${UPSTREAM_REPO}"
    git -C "$SOURCE_DIR" reset --hard --quiet "origin/${UPSTREAM_BRANCH}" \
      || die "failed to reset upstream cache to origin/${UPSTREAM_BRANCH}"
  else
    rm -rf "$SOURCE_DIR"
    git clone --quiet --branch "$UPSTREAM_BRANCH" --depth 1 \
      "$UPSTREAM_REPO" "$SOURCE_DIR" \
      || die "failed to clone upstream from ${UPSTREAM_REPO}"
  fi
}

# ── Manifest ────────────────────────────────────────────────────────────────

manifest_entry_for() {
  # Look up the recorded {upstream_hash, local_hash} at last reconcile.
  # Echo two fields tab-separated, or two empty fields if no record.
  if [ ! -f "$MANIFEST_FILE" ]; then
    printf '\t'; return
  fi
  jq -r --arg p "$1" \
    '(.files[$p] // {}) | "\(.upstream_hash // "")\t\(.local_hash // "")"' \
    "$MANIFEST_FILE" 2>/dev/null
}

# ── Plan ────────────────────────────────────────────────────────────────────

build_plan() {
  sync_upstream

  local upstream_version
  upstream_version="$(tr -d '[:space:]' < "${SOURCE_DIR}/VERSION")"

  # Walk upstream-managed files.
  local upstream_files
  upstream_files="$(git -C "$SOURCE_DIR" ls-files)"

  # Per-category JSONL temp files. Each plan loop appends one line per entry
  # via a single `jq -n` invocation; arrays are slurped into `jq -s '.'` once
  # at the end. This replaces the previous `arr=$(jq ... <<<"$arr")` pattern
  # which was O(N²) (each iteration re-parsed and re-serialized the growing
  # array) and forked jq once per category per row.
  local plan_tmp; plan_tmp=$(mktemp -d) || die "mktemp -d failed"
  : > "$plan_tmp/install.jsonl"
  : > "$plan_tmp/update.jsonl"
  : > "$plan_tmp/skip.jsonl"
  : > "$plan_tmp/conflict.jsonl"
  : > "$plan_tmp/preserved.jsonl"
  : > "$plan_tmp/local_only.jsonl"

  while IFS= read -r path; do
    [ -z "$path" ] && continue
    is_managed "$path" || continue

    if is_preserved "$path"; then
      jq -nc --arg p "$path" '$p' >> "$plan_tmp/preserved.jsonl"
      continue
    fi

    local up_hash local_hash man_hash local_path
    local_path="${REPO_ROOT}/${path}"
    up_hash="$(sha256 "${SOURCE_DIR}/${path}")"

    if [ ! -e "$local_path" ]; then
      local_hash=""
    else
      local_hash="$(sha256 "$local_path")"
    fi

    local man_up man_local
    IFS=$'\t' read -r man_up man_local < <(manifest_entry_for "$path")

    if [ -z "$local_hash" ]; then
      jq -nc --arg p "$path" --arg u "$up_hash" \
        '{path:$p, upstream_hash:$u}' >> "$plan_tmp/install.jsonl"
    elif [ "$local_hash" = "$up_hash" ]; then
      jq -nc --arg p "$path" '$p' >> "$plan_tmp/skip.jsonl"
    elif [ -z "$man_up" ] && [ -z "$man_local" ]; then
      # No provenance — could be local-only edits or a pre-existing file.
      jq -nc \
        --arg p "$path" --arg u "$up_hash" --arg l "$local_hash" \
        --arg mu "" --arg ml "" \
        --arg r "no manifest record (first run or pre-existing local file)" \
        '{path:$p, upstream_hash:$u, local_hash:$l, manifest_upstream:$mu, manifest_local:$ml, reason:$r}' \
        >> "$plan_tmp/conflict.jsonl"
    elif [ "$man_up" = "$up_hash" ]; then
      # Upstream hasn't moved since last reconcile.
      if [ "$man_local" = "$local_hash" ]; then
        # User's previously pinned version is still in place — leave alone.
        jq -nc --arg p "$path" '$p' >> "$plan_tmp/skip.jsonl"
      else
        # User's pinned version has been edited since the last reconcile.
        jq -nc \
          --arg p "$path" --arg u "$up_hash" --arg l "$local_hash" \
          --arg mu "$man_up" --arg ml "$man_local" \
          --arg r "local edits since last reconcile (upstream unchanged)" \
          '{path:$p, upstream_hash:$u, local_hash:$l, manifest_upstream:$mu, manifest_local:$ml, reason:$r}' \
          >> "$plan_tmp/conflict.jsonl"
      fi
    else
      # Upstream advanced.
      if [ "$man_local" = "$local_hash" ]; then
        # Local untouched since last reconcile → safe to update.
        jq -nc --arg p "$path" --arg u "$up_hash" --arg l "$local_hash" \
          '{path:$p, upstream_hash:$u, local_hash:$l}' >> "$plan_tmp/update.jsonl"
      else
        # Both upstream and local advanced.
        jq -nc \
          --arg p "$path" --arg u "$up_hash" --arg l "$local_hash" \
          --arg mu "$man_up" --arg ml "$man_local" \
          --arg r "local edits + upstream changes" \
          '{path:$p, upstream_hash:$u, local_hash:$l, manifest_upstream:$mu, manifest_local:$ml, reason:$r}' \
          >> "$plan_tmp/conflict.jsonl"
      fi
    fi
  done <<<"$upstream_files"

  # Detect local-only files inside managed dirs (custom skills, agents, etc.).
  local upstream_set="$(printf '%s\n' "$upstream_files" | sort)"
  local managed_dirs=(
    "${REPO_ROOT}/skills"
    "${REPO_ROOT}/agents"
    "${REPO_ROOT}/prompts"
    "${REPO_ROOT}/.claude/hooks"
    "${REPO_ROOT}/bin"
  )
  for dir in "${managed_dirs[@]}"; do
    [ -d "$dir" ] || continue
    while IFS= read -r f; do
      local rel="${f#${REPO_ROOT}/}"
      is_managed "$rel" || continue
      is_preserved "$rel" && continue
      # Skip if upstream ships this exact path.
      if grep -qxF "$rel" <<<"$upstream_set"; then continue; fi
      jq -nc --arg p "$rel" '$p' >> "$plan_tmp/local_only.jsonl"
    done < <(find "$dir" -type f 2>/dev/null)
  done

  # Slurp each JSONL file into a JSON array — one jq invocation per category
  # instead of one per row.
  local install_arr update_arr skip_arr conflict_arr preserved_arr local_only_arr
  install_arr="$(jq -cs '.' "$plan_tmp/install.jsonl")"
  update_arr="$(jq -cs '.' "$plan_tmp/update.jsonl")"
  skip_arr="$(jq -cs '.' "$plan_tmp/skip.jsonl")"
  conflict_arr="$(jq -cs '.' "$plan_tmp/conflict.jsonl")"
  preserved_arr="$(jq -cs '.' "$plan_tmp/preserved.jsonl")"
  local_only_arr="$(jq -cs '.' "$plan_tmp/local_only.jsonl")"
  rm -rf "$plan_tmp"

  local migration_arr; migration_arr="$(layout_migration_json)"

  jq -n \
    --arg lv "$LOCAL_VERSION" \
    --arg uv "$upstream_version" \
    --arg sd "$SOURCE_DIR" \
    --argjson install "$install_arr" \
    --argjson update "$update_arr" \
    --argjson skip "$skip_arr" \
    --argjson conflict "$conflict_arr" \
    --argjson preserved "$preserved_arr" \
    --argjson local_only "$local_only_arr" \
    --argjson migration "$migration_arr" \
    '{
      local_version: $lv,
      upstream_version: $uv,
      source_dir: $sd,
      needs_layout_migration: $migration,
      actions: {
        install: $install,
        update_safe: $update,
        skip: $skip,
        conflict: $conflict
      },
      preserved: $preserved,
      local_only: $local_only
    }'
}

# ── Apply ───────────────────────────────────────────────────────────────────

copy_file() {
  # $1 = path relative to repo root (== path relative to upstream root).
  # Fail loud on any step so apply_plan aborts before the manifest is written —
  # without this, a partial copy leaves the on-disk state inconsistent with
  # what the manifest claims, and the next --plan invocation mis-diagnoses
  # every undelivered file as a user-pinned conflict.
  local src="${SOURCE_DIR}/$1"
  local dst="${REPO_ROOT}/$1"
  mkdir -p "$(dirname "$dst")" || die "copy_file: mkdir failed for $(dirname "$dst")"
  cp "$src" "$dst" || die "copy_file: cp failed for $1"
  # Preserve executable bit for shell scripts and bin/.
  case "$1" in
    bin/*|*.sh) chmod +x "$dst" || die "copy_file: chmod failed for $dst" ;;
  esac
}

apply_plan() {
  local plan_json="$1"
  local resolution_file="$2"

  [ -f "$resolution_file" ] || die "resolution file not found: $resolution_file"

  # Refuse to apply against an un-migrated old-layout install. Without this,
  # files would be written to top-level skills/, agents/, prompts/ while
  # Claude Code continues reading from the real .claude/<X>/ dirs that the
  # plan compared against — invisible-but-installed is the worst failure
  # mode. The skill routes through --migrate-layout; the guard exists for
  # direct CLI use that bypasses the skill.
  local pending_migration; pending_migration="$(detect_old_layout)"
  if [ -n "$pending_migration" ]; then
    {
      echo "harness-update: refusing to --apply on an un-migrated old-layout install."
      echo "The following directories are still real (not symlinks):"
      while IFS=$'\t' read -r from to; do
        [ -z "$from" ] && continue
        echo "  ${from} → ${to}/"
      done <<<"$pending_migration"
      echo "Run: bin/harness-update --migrate-layout"
      echo "Then re-run --plan and --apply against the fresh plan."
    } >&2
    exit 1
  fi

  # Validate resolution: every conflict must have a decision.
  local conflicts
  conflicts="$(jq -r '.actions.conflict[].path' <<<"$plan_json")"

  while IFS= read -r path; do
    [ -z "$path" ] && continue
    local decision
    decision="$(jq -r --arg p "$path" '.conflicts[$p] // ""' "$resolution_file")"
    case "$decision" in
      keep-mine|take-upstream) ;;
      abort) die "aborted by resolution" ;;
      "") die "no resolution for conflict: $path" ;;
      *) die "invalid resolution for $path: $decision (expected keep-mine|take-upstream|abort)" ;;
    esac
  done <<<"$conflicts"

  # Build the new manifest. Each entry records {upstream_hash, local_hash}
  # at reconcile time, so a future plan can tell "user pinned a custom version"
  # apart from "user untouched since install".
  #
  # Append one JSON object per record to a JSONL file; reduce into a single
  # object once at the end via `jq -s 'add'`. Avoids the O(N²) cost of the
  # prior pattern (`new_manifest=$(jq ... <<<"$new_manifest")` re-parsed and
  # re-serialized the growing object every iteration).
  local manifest_lines; manifest_lines=$(mktemp) || die "mktemp failed"
  local applied_count=0

  record() {
    # $1 = path, $2 = upstream_hash (current), $3 = local_hash to record
    jq -nc --arg p "$1" --arg u "$2" --arg l "$3" \
      '{($p): {upstream_hash: $u, local_hash: $l}}' >> "$manifest_lines"
  }

  # 1. install
  while IFS= read -r row; do
    [ -z "$row" ] && continue
    local path up_hash
    path="$(jq -r '.path' <<<"$row")"
    up_hash="$(jq -r '.upstream_hash' <<<"$row")"
    copy_file "$path"
    record "$path" "$up_hash" "$up_hash"
    applied_count=$((applied_count + 1))
    echo "  installed: $path" >&2
  done < <(jq -c '.actions.install[]' <<<"$plan_json")

  # 2. update_safe
  while IFS= read -r row; do
    [ -z "$row" ] && continue
    local path up_hash
    path="$(jq -r '.path' <<<"$row")"
    up_hash="$(jq -r '.upstream_hash' <<<"$row")"
    copy_file "$path"
    record "$path" "$up_hash" "$up_hash"
    applied_count=$((applied_count + 1))
    echo "  updated:   $path" >&2
  done < <(jq -c '.actions.update_safe[]' <<<"$plan_json")

  # 3. skip — record provenance so a future divergence can be detected.
  while IFS= read -r path; do
    [ -z "$path" ] && continue
    local up_hash
    up_hash="$(sha256 "${SOURCE_DIR}/${path}")"
    record "$path" "$up_hash" "$up_hash"
  done < <(jq -r '.actions.skip[]' <<<"$plan_json")

  # 4. conflict — apply user's decision.
  while IFS= read -r row; do
    [ -z "$row" ] && continue
    local path up_hash local_hash
    path="$(jq -r '.path' <<<"$row")"
    up_hash="$(jq -r '.upstream_hash' <<<"$row")"
    local_hash="$(jq -r '.local_hash' <<<"$row")"
    local decision
    decision="$(jq -r --arg p "$path" '.conflicts[$p]' "$resolution_file")"
    if [ "$decision" = "take-upstream" ]; then
      copy_file "$path"
      record "$path" "$up_hash" "$up_hash"
      applied_count=$((applied_count + 1))
      echo "  resolved:  $path  (took upstream)" >&2
    else
      # keep-mine: record both upstream_hash (so future runs know which
      # upstream version was declined) and local_hash (so a later edit to
      # the kept file is detected).
      record "$path" "$up_hash" "$local_hash"
      echo "  kept:      $path  (kept local version)" >&2
    fi
  done < <(jq -c '.actions.conflict[]' <<<"$plan_json")

  # Reduce per-record JSONL objects into one files object.
  local new_manifest
  new_manifest="$(jq -cs 'add // {}' "$manifest_lines")"
  rm -f "$manifest_lines"

  # Write the new manifest atomically — tmp + rename. Without this, two
  # concurrent /harness-update runs sharing $HOME/.agent-harness could leave
  # the file half-written or last-writer-wins.
  local upstream_version
  upstream_version="$(jq -r '.upstream_version' <<<"$plan_json")"
  local manifest_tmp="${MANIFEST_FILE}.tmp.$$"
  jq -n \
    --arg v "$upstream_version" \
    --arg t "$(date -u +'%Y-%m-%dT%H:%M:%SZ')" \
    --argjson files "$new_manifest" \
    '{version_when_installed: $v, installed_at: $t, files: $files}' \
    > "$manifest_tmp" \
    || { rm -f "$manifest_tmp"; die "manifest jq failed"; }
  mv "$manifest_tmp" "$MANIFEST_FILE" \
    || { rm -f "$manifest_tmp"; die "manifest rename failed"; }

  # Mark just-upgraded so harness-update-check surfaces the JUST_UPGRADED
  # notice on the next skill invocation.
  if [ "$LOCAL_VERSION" != "$upstream_version" ]; then
    echo "$LOCAL_VERSION" > "$JUST_UPGRADED_FILE"
  fi

  # Bust the update-check cache so the user sees fresh state immediately.
  rm -f "$CACHE_FILE"

  echo "" >&2
  echo "Applied $applied_count change(s). VERSION: ${LOCAL_VERSION} → ${upstream_version}" >&2
}

# ── Entry point ─────────────────────────────────────────────────────────────

usage() {
  cat <<USAGE
Usage:
  harness-update --plan
  harness-update --migrate-layout
  harness-update --apply --resolve <resolution.json> --from <plan.json>

Phases:
  --plan
      Sync upstream and emit a JSON plan on stdout. No writes.
      The plan includes a "needs_layout_migration" field listing any
      .claude/{skills,agents,commands} that are still real directories
      and need to be flipped to top-level dirs + symlinks before the
      upstream copy can be applied cleanly.

  --migrate-layout
      Move .claude/skills, .claude/agents, .claude/commands (any that are
      still real directories) to top-level skills/, agents/, prompts/, and
      replace the originals with symlinks. Rewrites installed-manifest.json
      paths in place. Run this once on old-layout installs before --apply.

  --apply --resolve <file> --from <file>
      Apply the supplied plan. <resolution.json> must decide every conflict
      with one of: "keep-mine", "take-upstream", "abort".
      <plan.json> is the output of a previous --plan run.

State:
  ~/.agent-harness/source                  upstream cache (cloned/fetched)
  ~/.agent-harness/installed-manifest.json provenance: path -> sha at install
  ~/.agent-harness/just-upgraded-from      written on success; consumed by
                                           bin/harness-update-check
USAGE
}

MODE=""
RESOLVE_FILE=""
PLAN_FILE=""

while [ $# -gt 0 ]; do
  case "$1" in
    --plan) MODE="plan"; shift ;;
    --apply) MODE="apply"; shift ;;
    --migrate-layout) MODE="migrate-layout"; shift ;;
    --resolve) RESOLVE_FILE="$2"; shift 2 ;;
    --from) PLAN_FILE="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) usage >&2; die "unknown argument: $1" ;;
  esac
done

case "$MODE" in
  plan)
    build_plan
    ;;
  migrate-layout)
    migrate_layout
    ;;
  apply)
    [ -n "$RESOLVE_FILE" ] || { usage >&2; die "--apply requires --resolve <file>"; }
    [ -n "$PLAN_FILE" ]    || { usage >&2; die "--apply requires --from <plan.json>"; }
    [ -f "$PLAN_FILE" ]    || die "plan file not found: $PLAN_FILE"
    plan_json="$(cat "$PLAN_FILE")"
    apply_plan "$plan_json" "$RESOLVE_FILE"
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
