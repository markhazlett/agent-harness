#!/usr/bin/env bash
# =============================================================================
# conductor-dispatch — spawn a new Conductor workspace via deep link, with a
# plan markdown file attached.
#
# Usage:
#   conductor-dispatch <path-to-plan.md>          # open + print
#   conductor-dispatch <path-to-plan.md> --open   # open only
#   conductor-dispatch <path-to-plan.md> --print  # print URL, don't open
#
# Env overrides (used by tests):
#   CONDUCTOR_REPO_NAME — override repo-name detection
# =============================================================================
set -euo pipefail

# ── Mode gate: skip entirely when host is not Conductor ──────────────────────
# Same pattern as bin/conductor-status. Unset/empty = conductor (backward compat).
_SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
_HARNESS_CONFIG="$_SCRIPT_DIR/../.claude/hooks/harness.config.sh"
if [ -z "${HARNESS_HOST:-}" ] && [ -f "$_HARNESS_CONFIG" ]; then
  # shellcheck source=../.claude/hooks/harness.config.sh
  source "$_HARNESS_CONFIG" 2>/dev/null || true
fi
if [ "${HARNESS_HOST:-conductor}" != "conductor" ]; then
  exit 0
fi
unset _SCRIPT_DIR _HARNESS_CONFIG

plan="${1:?usage: conductor-dispatch <plan.md> [--open|--print]}"
mode="${2:-both}"

[ -f "$plan" ] || { echo "error: plan not found: $plan" >&2; exit 1; }

if [ -n "${CONDUCTOR_REPO_NAME:-}" ]; then
  repo="$CONDUCTOR_REPO_NAME"
else
  root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  parent="$(dirname "$root")"
  # Conductor layout: ~/conductor/workspaces/<repo>/<workspace>. If parent is
  # under a "workspaces" dir, the repo name is one level up. Otherwise fall
  # back to the directory name of the git root itself.
  if [[ "$(basename "$parent")" != "workspaces" && "$parent" != *"/conductor/workspaces/"* ]]; then
    repo="$(basename "$root")"
  else
    repo="$(basename "$parent")"
  fi
fi

b64=$(base64 < "$plan" | tr -d '\n')
# URL-percent-encode $repo so special chars don't corrupt the query string.
repo_enc=$(jq -rn --arg v "$repo" '$v|@uri')
url="conductor://async?repo=${repo_enc}&plan=${b64}"

case "$mode" in
  --print) echo "$url" ;;
  --open)
    if command -v open >/dev/null 2>&1; then
      open "$url"
    else
      echo "error: 'open' not found; run with --print and open manually" >&2
      echo "$url"
      exit 1
    fi
    ;;
  both|"")
    if command -v open >/dev/null 2>&1; then
      open "$url"
    else
      echo "warning: 'open' not found; here is the URL to open manually:" >&2
    fi
    echo "$url"
    ;;
  *) echo "error: unknown mode '$mode'" >&2; exit 2 ;;
esac
