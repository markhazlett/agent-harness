#!/usr/bin/env bash
# bin/test-terminal-states — verify the 4 skills designated by G9 declare a
# Terminal State section.
#
# Per the harness-rigorization workstream's G9 plan, these skills must each
# contain a `## Terminal State` section naming the next skill and forbidding
# the alternatives:
#
#   /lg-scaffold   — terminal state hands off to /lg-add
#   /lg-design     — terminal state hands off to /lg-scaffold
#   /build-plan    — terminal state declares mandatory quality skills
#   /tdd           — terminal state hands off to /e2e-verify (conditional)
#
# Other rigid skills (e.g., /security-review, /pre-deploy, /ship, /debug,
# /incident, /db-review, /e2e-verify, /lg-review) describe their handoffs in
# their "What this skill does NOT cover" sections. Those are sufficient for
# the workstream's terminal-state goal; this validator does not require a
# named "Terminal State" section on them.
#
# Exit codes:
#   0  every required skill declares Terminal State
#   1  one or more required skills are missing Terminal State
#   2  usage error / repo not found

set -u

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$repo_root" ]; then
  echo "FAIL: not inside a git repo" >&2
  exit 2
fi
cd "$repo_root" || exit 2

REQUIRED_SKILLS="lg-scaffold lg-design build-plan tdd"

has_terminal_state() {
  grep -qiE '^##[[:space:]]+Terminal[[:space:]]+State' "$1"
}

fail=0
checked=0
missing=()

for name in $REQUIRED_SKILLS; do
  skill_md=".claude/skills/$name/SKILL.md"
  if [ ! -f "$skill_md" ]; then
    echo "FAIL  $name (SKILL.md not found)"
    missing+=("$name")
    fail=$((fail + 1))
    continue
  fi
  checked=$((checked + 1))
  if has_terminal_state "$skill_md"; then
    echo "PASS  $name"
  else
    echo "FAIL  $name (missing '## Terminal State' section)"
    missing+=("$name")
    fail=$((fail + 1))
  fi
done

echo
echo "Terminal-state validation: $((checked - fail))/$checked required skills declare Terminal State."
if [ "$fail" -ne 0 ]; then
  echo "Missing: ${missing[*]}"
  exit 1
fi
exit 0
